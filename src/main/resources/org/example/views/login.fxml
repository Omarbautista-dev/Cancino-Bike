<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="560.0"
           prefWidth="625.0"
           styleClass="root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.controllers.LoginController">

    <children>
        <VBox alignment="TOP_CENTER"
              prefWidth="585.0"
              prefHeight="505.0"
              maxWidth="585.0"
              maxHeight="505.0"
              spacing="0"
              styleClass="login-card">

            <padding>
                <Insets top="65" right="40" bottom="40" left="40"/>
            </padding>

            <children>
                <Label text="Cancino Bike" styleClass="titulo"/>

                <Label text="Innovación, calidad y confianza en cada pieza"
                       styleClass="subtitulo"/>

                <Label prefHeight="28"/>

                <Label text="Usuario" maxWidth="999" styleClass="label-form"/>

                <TextField fx:id="txtUsuario"
                           prefHeight="56"
                           maxWidth="999"
                           promptText="Ingrese usuario"
                           styleClass="input"/>

                <Label prefHeight="26"/>

                <Label text="Contraseña" maxWidth="999" styleClass="label-form"/>

                <PasswordField fx:id="txtPassword"
                               prefHeight="56"
                               maxWidth="999"
                               promptText="Ingrese contraseña"
                               styleClass="input"/>

                <Label prefHeight="74"/>

                <Button text="Iniciar Sesion"
                        onAction="#iniciarSesion"
                        prefHeight="42"
                        maxWidth="999"
                        styleClass="btn-login"/>
            </children>
        </VBox>
    </children>
</StackPane>