<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.SeguridadController"
            prefWidth="1100"
            prefHeight="780"
            styleClass="root-dashboard">

    <VBox AnchorPane.topAnchor="20"
          AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10"
          AnchorPane.bottomAnchor="10"
          styleClass="main-box">

        <HBox styleClass="header">
            <ImageView fx:id="logoImage"
                       fitWidth="58"
                       fitHeight="58"
                       preserveRatio="true"/>

            <VBox styleClass="title-box">
                <Label text="Refaccionaria" styleClass="title"/>
                <Label text="Cancino Bike" styleClass="title"/>
            </VBox>
        </HBox>

        <HBox styleClass="menu-bar">
            <Button text="Dashboard" onAction="#abrirDashboard" styleClass="menu-button"/>
            <Button text="Cambiar Password" onAction="#mostrarCambiarPassword" styleClass="menu-button"/>
            <Button text="Usuarios" onAction="#mostrarUsuarios" styleClass="menu-button"/>
            <Button text="Privilegios" onAction="#mostrarPrivilegios" styleClass="menu-button"/>
            <Button text="Accesos" onAction="#mostrarAccesos" styleClass="menu-button"/>
        </HBox>

        <VBox VBox.vgrow="ALWAYS" styleClass="content">

            <HBox styleClass="module-title-bar">
                <Label text="SEGURIDAD" styleClass="module-title"/>
            </HBox>

            <VBox fx:id="panelCambiarPassword"
                  spacing="12"
                  styleClass="password-panel">

                <Label text="CAMBIAR PASSWORD" styleClass="form-title"/>

                <TextField fx:id="txtUsuario"
                           promptText="Usuario"
                           prefWidth="300"/>

                <PasswordField fx:id="txtPasswordActual"
                               promptText="Password actual"
                               prefWidth="300"/>

                <PasswordField fx:id="txtPasswordNuevo"
                               promptText="Nuevo password"
                               prefWidth="300"/>

                <PasswordField fx:id="txtPasswordConfirmar"
                               promptText="Confirmar nuevo password"
                               prefWidth="300"/>

                <HBox spacing="10">
                    <Button text="Cambiar password"
                            onAction="#cambiarPassword"
                            styleClass="menu-button"/>

                    <Button text="Limpiar"
                            onAction="#limpiarFormulario"
                            styleClass="menu-button"/>
                </HBox>

            </VBox>

            <VBox fx:id="panelUsuarios"
                  spacing="10"
                  visible="false"
                  managed="false"
                  styleClass="password-panel"
                  VBox.vgrow="ALWAYS">

                <Label text="USUARIOS" styleClass="form-title"/>

                <HBox spacing="8">
                    <Label text="Buscar:" styleClass="form-label"/>

                    <TextField fx:id="txtBuscarUsuario"
                               promptText="Usuario, nombre o rol"
                               prefWidth="320"/>
                </HBox>

                <TableView fx:id="tablaUsuarios"
                           prefHeight="300"
                           VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colUsuarioId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colUsuarioLogin" text="Usuario" prefWidth="150"/>
                        <TableColumn fx:id="colUsuarioNombre" text="Nombre completo" prefWidth="250"/>
                        <TableColumn fx:id="colUsuarioRol" text="Rol" prefWidth="150"/>
                        <TableColumn fx:id="colUsuarioEstado" text="Estado" prefWidth="100"/>
                        <TableColumn fx:id="colUsuarioFecha" text="Fecha registro" prefWidth="180"/>
                    </columns>
                </TableView>

                <VBox spacing="8">
                    <Label text="DATOS DEL USUARIO" styleClass="form-title"/>

                    <HBox spacing="8">
                        <TextField fx:id="txtUsuarioNuevo"
                                   promptText="Usuario"
                                   prefWidth="170"/>

                        <PasswordField fx:id="txtPasswordUsuario"
                                       promptText="Password inicial"
                                       prefWidth="170"/>

                        <TextField fx:id="txtNombreCompletoUsuario"
                                   promptText="Nombre completo"
                                   prefWidth="260"/>

                        <ComboBox fx:id="cbRolUsuario"
                                  promptText="Rol"
                                  prefWidth="160"/>

                        <ComboBox fx:id="cbEstadoUsuario"
                                  promptText="Estado"
                                  prefWidth="120"/>
                    </HBox>

                    <HBox spacing="8">
                        <Button text="Nuevo"
                                onAction="#limpiarUsuario"
                                styleClass="menu-button"/>

                        <Button text="Guardar usuario"
                                onAction="#guardarUsuario"
                                styleClass="menu-button"/>

                        <Button text="Actualizar usuario"
                                onAction="#actualizarUsuario"
                                styleClass="menu-button"/>

                        <Button text="Activar/Desactivar"
                                onAction="#cambiarEstadoUsuario"
                                styleClass="menu-button"/>
                    </HBox>
                </VBox>

            </VBox>

        </VBox>

    </VBox>

</AnchorPane>