<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.InventarioController"
            prefWidth="1100"
            prefHeight="780"
            styleClass="root-dashboard">

    <VBox AnchorPane.topAnchor="20"
          AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10"
          AnchorPane.bottomAnchor="10"
          styleClass="main-box">

        <HBox styleClass="header">
            <ImageView fx:id="logoImage"
                       fitWidth="58"
                       fitHeight="58"
                       preserveRatio="true"/>

            <VBox styleClass="title-box">
                <Label text="Refaccionaria" styleClass="title"/>
                <Label text="Cancino Bike" styleClass="title"/>
            </VBox>
        </HBox>

        <HBox styleClass="menu-bar">

            <Button text="Dashboard"
                    onAction="#abrirDashboard"
                    styleClass="menu-button"/>

            <Button text="Productos"
                    onAction="#modoProductos"
                    styleClass="menu-button"/>

            <Button text="Actualizar stock"
                    onAction="#modoActualizarStock"
                    styleClass="menu-button"/>

            <Button text="Lotes"
                    onAction="#modoControlLotes"
                    styleClass="menu-button"/>

            <Button text="Ajustes"
                    onAction="#modoAjusteInventario"
                    styleClass="menu-button"/>

            <Button text="Precios"
                    onAction="#modoActualizarPrecios"
                    styleClass="menu-button"/>

        </HBox>

        <VBox VBox.vgrow="ALWAYS" styleClass="content">

            <HBox styleClass="module-title-bar">
                <Label text="INVENTARIO" styleClass="module-title"/>
            </HBox>


            <HBox styleClass="info-bar">
                <Label text="REPORTE DE INVENTARIO" styleClass="info-label"/>
                <Label fx:id="lblCantidadProductos"
                       text="Cantidad de productos: 0"
                       styleClass="info-label"/>
                <Label fx:id="lblCostoInventario"
                       text="Costo de inventario: $0.00"
                       styleClass="info-label"/>
            </HBox>

            <HBox spacing="8" styleClass="search-bar">
                <Label text="Buscar:" styleClass="form-label"/>
                <TextField fx:id="txtBuscar"
                           promptText="Código, modelo o nombre"
                           prefWidth="350"/>
            </HBox>

            <TableView fx:id="tablaInventario" VBox.vgrow="ALWAYS" styleClass="inventario-table">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="55"/>
                    <TableColumn fx:id="colCodigo" text="Código" prefWidth="110"/>
                    <TableColumn fx:id="colModelo" text="Modelo" prefWidth="110"/>
                    <TableColumn fx:id="colProducto" text="Producto" prefWidth="170"/>
                    <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="170"/>
                    <TableColumn fx:id="colCompra" text="Compra" prefWidth="80"/>
                    <TableColumn fx:id="colMenudeo" text="Menudeo" prefWidth="80"/>
                    <TableColumn fx:id="colMayoreo" text="Mayoreo" prefWidth="80"/>
                    <TableColumn fx:id="colStock" text="Stock" prefWidth="70"/>
                    <TableColumn fx:id="colMinimo" text="Mínimo" prefWidth="70"/>
                    <TableColumn fx:id="colProveedor" text="Proveedor" prefWidth="145"/>
                </columns>
            </TableView>

            <VBox styleClass="form-panel" spacing="8">

                <Label text="DATOS DEL PRODUCTO" styleClass="form-title"/>

                <HBox spacing="8">
                    <TextField fx:id="txtCodigo" promptText="Código de barras" prefWidth="150"/>
                    <TextField fx:id="txtModelo" promptText="Modelo" prefWidth="130"/>
                    <TextField fx:id="txtNombre" promptText="Nombre del producto" prefWidth="220"/>
                    <TextField fx:id="txtDescripcion" promptText="Descripción" prefWidth="250"/>
                </HBox>

                <HBox spacing="8">
                    <TextField fx:id="txtCompra" promptText="Precio compra" prefWidth="130"/>
                    <TextField fx:id="txtMenudeo" promptText="Precio menudeo" prefWidth="130"/>
                    <TextField fx:id="txtMayoreo" promptText="Precio mayoreo" prefWidth="130"/>
                    <TextField fx:id="txtStock" promptText="Stock" prefWidth="100"/>
                    <TextField fx:id="txtMinimo" promptText="Stock mínimo" prefWidth="120"/>
                    <ComboBox fx:id="cbProveedor" promptText="Proveedor" prefWidth="180"/>
                </HBox>

                <HBox spacing="8">
                    <Button text="Nuevo" onAction="#limpiarFormulario" styleClass="menu-button"/>
                    <Button text="Guardar" onAction="#guardarProducto" styleClass="menu-button"/>
                    <Button text="Actualizar" onAction="#actualizarProducto" styleClass="menu-button"/>
                    <Button text="Eliminar" onAction="#eliminarProducto" styleClass="menu-button"/>
                </HBox>

            </VBox>

        </VBox>

    </VBox>

</AnchorPane>